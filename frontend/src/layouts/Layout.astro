---
import '../styles/global.css';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en" class="bg-background">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Every conflict has two stories. Find where they meet." />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body class="bg-background text-foreground antialiased selection:bg-accent/30 selection:text-accent">
		<slot />
	</body>
</html>
